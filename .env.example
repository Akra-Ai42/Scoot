# === GEMINI (Google AI Studio) ===
# Obtenir sur : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === SUPABASE ===
# Obtenir sur : https://supabase.com → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# === TOGETHER AI (Newsletter) ===
# Obtenir sur : https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here

# === NEWSLETTER DELIVERY ===
# Choisir Loops.so OU Brevo
LOOPS_API_KEY=your_loops_api_key_here
# BREVO_API_KEY=your_brevo_api_key_here

# === CONFIG ===
SCOUT_RUN_HOUR=2        # Heure d'exécution UTC (02h00)
MAX_THREADS_PER_RUN=15  # Nombre max de threads Reddit à analyser
